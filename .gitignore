# Custom Exclusions (Existing project setting)
/.github

# =========================================================================
# Maven / Java Build Artifacts
# =========================================================================
# Ignore the target directory which contains compiled classes, packaged JARs/WARs, 
# and other build output.
**/target/

# Ignore release-related files generated by Maven plugins
pom.xml.tag
pom.xml.releaseBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# =========================================================================
# Node.js / Web Dependencies & Logs
# =========================================================================
# Ignore node_modules directory which contains downloaded npm packages.
**/node_modules/

# Logs generated during package installation/runs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =========================================================================
# IntelliJ IDEA
# =========================================================================
# Ignore project-specific settings, modules, workspace files, and build output
.idea/
*.iws
*.iml
*.ipr
out/

# =========================================================================
# Eclipse IDE
# =========================================================================
# Ignore Eclipse metadata, settings, classpath, and project definitions
.metadata/
bin/
.settings/
.classpath
.project
.factorypath

# =========================================================================
# Visual Studio Code
# =========================================================================
# Keep essential shared configurations but ignore other user-specific workspace state
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.code-workspace

# =========================================================================
# Operating System Files
# =========================================================================
# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows system files
Thumbs.db
ehthumbs.db